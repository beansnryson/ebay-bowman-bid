# eBay Browse API credentials — copy to .env and fill in
# Get these at https://developer.ebay.com (create a Production keyset)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=

# Optional: eBay Partner Network campaign ID for affiliate tracking
EBAY_EPN_CAMPAIGN_ID=

# Optional: cap on number of auctions to score per run
MAX_AUCTIONS_TO_SCAN=500
